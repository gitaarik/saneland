# Generated active-theme / gui-size symlinks — created by install.sh (and
# flipped by the `theme` script). The tracked sources are the -dark/-light
# variants; the active symlink is machine state, not source.
/config/eww/eww.scss
/config/hypr/border-colors.conf
/config/rofi/colorScheme.rasi
/config/rofi/guiSize.rasi
/config/swaync/style.css
/config/gtk-3.0/settings.ini
/config/gtk-3.0/gtk.css

# Per-machine overrides — seeded from *.example by install.sh, then yours to
# edit. Keeps the tracked base config byte-identical for everyone.
/config/hypr/local.conf
/config/eww/local.yuck
/config/saneland/theme.local.sh

# Whole-file overlay tree (your private tweaks; can be its own repo). Only the
# README is tracked — everything you drop in is git-ignored. See CUSTOMIZING.md.
/local/*
!/local/README.md

# User-supplied wallpaper images (drop your own in — see wallpapers/README.md)
/wallpapers/dark/*
/wallpapers/light/*
!/wallpapers/*/.gitkeep

# OS / editor cruft
*.swp
*~
.DS_Store
