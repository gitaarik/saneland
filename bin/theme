#!/usr/bin/env bash
#
# theme — switch the desktop between dark and light.
#
# Flips symlinks and reloads the desktop-shell apps that ship with this
# project: the eww bar, swaync, GTK, rofi, and the wallpaper. The active
# theme is recorded in ~/.cache/current-theme so anything else that wants
# to follow it can read that file.
#
# Usage: theme {dark|light|toggle}

case "$1" in
    dark|light)
        COLOR_SCHEME=$1
        ;;
    toggle)
        # Flip whichever is current; default to switching TO light when no
        # cache exists yet (fresh boot state is dark).
        current=$(cat ~/.cache/current-theme 2>/dev/null || echo dark)
        COLOR_SCHEME=$([[ $current == dark ]] && echo light || echo dark)
        ;;
    *)
        echo "Usage: theme {dark|light|toggle}"
        exit 1
        ;;
esac

# Shared state file — read by anything that follows the active theme.
mkdir -p ~/.cache
echo "$COLOR_SCHEME" > ~/.cache/current-theme

# --- swaync — swap style-dark.css / style-light.css and reload ---
if [[ -d ~/.config/swaync ]]; then
    (cd ~/.config/swaync/ && ln -sf "style-$COLOR_SCHEME.css" style.css)
    swaync-client --reload-css &>/dev/null
fi

# --- eww bar — flip the palette SCSS and restart the daemon ---
# eww 0.5 caches the CSS provider for the daemon's lifetime, so `eww reload`
# re-reads the SCSS but doesn't replace the provider — window background
# colors stick. A full daemon restart is the only reliable way to apply a
# theme switch to a running bar. setsid -f detaches the kill+respawn so that
# when `theme` is called from an eww onclick, `eww kill` doesn't SIGHUP this
# script before the respawn lands.
if [[ -d ~/.config/eww ]] && pgrep -x eww >/dev/null; then
    (cd ~/.config/eww/ && ln -sf "eww-$COLOR_SCHEME.scss" eww.scss)
    setsid -f bash -c 'eww kill &>/dev/null; sleep 0.2; eww open bar &>/dev/null' &>/dev/null
fi

# --- Hyprland — border colors are hardcoded in hyprland.conf; reload it ---
if pgrep -x Hyprland >/dev/null; then
    hyprctl reload &>/dev/null
fi

# --- wallpaper — repaint immediately from the new theme's pool ---
# (hypr-wallpaper picks a random image from ~/.config/hypr/wallpapers/$scheme/;
# without this the rotation daemon would keep the old image until its next tick.)
if [[ -d ~/.config/hypr/wallpapers/$COLOR_SCHEME ]] && pgrep -x hyprpaper >/dev/null; then
    ~/.local/bin/hypr-wallpaper "$COLOR_SCHEME"
fi

# --- GTK ---
# Dark links the settings/css overrides; light removes them so GTK falls back
# to the system light theme. gsettings is what actually drives portal-aware
# GTK apps (Firefox, Thunderbird, file dialogs) to follow the scheme.
# Requires materia-gtk-theme + papirus-icon-theme (change the names below to
# use different themes).
export QT_QPA_PLATFORMTHEME=gtk2
if [[ -d ~/.config/gtk-3.0 ]]; then
    if [[ $COLOR_SCHEME == dark ]]; then
        (cd ~/.config/gtk-3.0/ && ln -sf settings-dark.ini settings.ini && ln -sf gtk-dark.css gtk.css)
    else
        (cd ~/.config/gtk-3.0/ && rm -f settings.ini gtk.css)
    fi
fi
if command -v gsettings &>/dev/null; then
    if [[ $COLOR_SCHEME == dark ]]; then
        gtk_scheme=prefer-dark;  gtk_theme=Materia-dark;  icon_theme=Papirus-Dark
    else
        # prefer-light (not "default") so xdg-desktop-portal exposes
        # org.freedesktop.appearance color-scheme = 2 ("prefer light"). Apps
        # like Qt 6.5+ and Telegram treat 0 ("no preference") as "don't
        # change" and would otherwise stay dark.
        gtk_scheme=prefer-light; gtk_theme=Materia-light; icon_theme=Papirus-Light
    fi
    gsettings set org.gnome.desktop.interface color-scheme "$gtk_scheme"
    gsettings set org.gnome.desktop.interface gtk-theme   "$gtk_theme"
    gsettings set org.gnome.desktop.interface icon-theme  "$icon_theme"
fi

# --- rofi — flip the color scheme include ---
if command -v rofi &>/dev/null && [[ -d ~/.config/rofi ]]; then
    (cd ~/.config/rofi/ && ln -sf "colorSchemes/$COLOR_SCHEME.rasi" colorScheme.rasi)
fi
