#!/usr/bin/bash
#
# Battery low-charge notifier.
#
# Started once from hyprland.conf's exec-once. Fires a swaync notification
# (notify-send) when the charge crosses a threshold *downward while
# discharging*, and clears it again once you plug in or recover. The eww bar
# already shows the percentage and recolors at these same tiers (low 30 /
# warning 20 / critical 10) — this adds the audible/visible heads-up so a
# drain doesn't go unnoticed while you're not looking at the bar.
#
# Timing is a hybrid (see the main loop): a slow periodic poll catches the
# capacity thresholds (there's no event for "crossed 20%"), while a udev
# subscription on the power_supply subsystem wakes us *instantly* on
# plug/unplug so dismissal and re-arming feel immediate rather than lagging a
# poll cycle. udev is generic Linux (ships with systemd/eudev), so this stays
# portable — nothing here is tied to Hyprland/eww/swaync.
#
# Thresholds mirror the bar's warning/critical color tiers so a notification
# fires exactly as the widget changes color (see eww.yuck):
WARN_PCT=20        # normal-urgency "battery low"
CRIT_PCT=10        # critical-urgency "battery critically low"
# Capacity poll cadence. Adaptive: capacity changes don't emit udev events (only
# plug/unplug do), so the percentage in a persistent popup is only as fresh as
# our poll. We poll slowly when healthy and fast once discharging in a low band,
# so the critical popup's percentage keeps pace with the eww systray (~30s)
# instead of lagging a full slow cycle behind.
INTERVAL=60        # seconds between polls when healthy / on AC
FAST_INTERVAL=20   # seconds between polls while discharging at/below WARN_PCT

# How long the warn popup stays on screen, in ms. swaync's global default for
# normal-urgency notifications is short (5s here), which is easy to miss, so we
# override it just for this one via notify-send -t. The critical popup gets no
# -t: it uses swaync's timeout-critical (0 = never) and persists until the
# battery is plugged in / recovers.
WARN_TIMEOUT_MS=15000

# Edge-triggering for the warn popup: fires once when the charge first drops
# to/below WARN_PCT, re-armed once it rises back above (or on AC). Without this
# we'd re-notify every poll for the whole time it sits in the low band.
warn_armed=1

# The critical popup persists (critical urgency never expires), so instead of
# firing once we keep it *current*: crit_shown_cap holds the percentage last
# rendered into it. On each poll below CRIT_PCT we re-issue only when the
# number changed, so it tracks 10 -> 9 -> 8 in place (reused id) rather than
# freezing at the crossing value. Empty means "not currently shown".
crit_shown_cap=""

# Server-assigned id of the low-battery notification currently on screen (empty
# when none). The critical notification has `critical` urgency, which swaync
# keeps on screen until it's *explicitly* dismissed — so once the situation is
# resolved (plugged in, or charge back above the band) we must close it
# ourselves via the freedesktop CloseNotification D-Bus method. We also reuse
# the id as the replace-id, so warn -> crit updates the same bubble instead of
# stacking a second one.
active_nid=""

read_first() { cat "$@" 2>/dev/null | head -1; }

# Close the on-screen low-battery notification, if any.
dismiss() {
    [[ -n $active_nid ]] || return
    gdbus call --session --dest org.freedesktop.Notifications \
        --object-path /org/freedesktop/Notifications \
        --method org.freedesktop.Notifications.CloseNotification "$active_nid" \
        >/dev/null 2>&1
    active_nid=""
}

# notify <urgency> <title> <body> [timeout_ms] — (re)raise the low-battery
# notification and remember its id. --print-id echoes the server-assigned id on
# stdout. A non-empty timeout_ms overrides swaync's default expiry for this one
# notification; omit it to use swaync's per-urgency default.
notify() {
    active_nid=$(notify-send --print-id -a "Battery" -u "$1" \
        ${active_nid:+-r "$active_nid"} ${4:+-t "$4"} -h "int:value:$cap" \
        "$2" "$3" 2>/dev/null)
}

# Read the current state and act on it. Idempotent: safe to call on every
# poll tick and on every power event.
evaluate() {
    cap=$(read_first /sys/class/power_supply/BAT*/capacity)
    local status online
    status=$(read_first /sys/class/power_supply/BAT*/status)
    online=$(read_first /sys/class/power_supply/A*/online)
    [[ -n $cap ]] || return

    # Treat "plugged in" as either the AC adapter reporting online or the
    # battery status saying Charging/Full — belt and braces because some
    # firmwares lag one of the two.
    local charging=0
    [[ $online == "1" || $status == "Charging" || $status == "Full" ]] && charging=1

    if (( charging )); then
        # On AC: clear any lingering low-battery notification and re-arm both
        # so the next unplug-and-drain triggers fresh ones.
        dismiss
        warn_armed=1
        crit_shown_cap=""
    elif (( cap <= CRIT_PCT )); then
        # Raise on first crossing and refresh in place as the charge keeps
        # dropping; skip when the number is unchanged so we don't re-alert
        # while it sits at the same percent.
        if [[ $crit_shown_cap != "$cap" ]]; then
            notify critical "Battery critically low" \
                "${cap}% remaining — plug in now."
            crit_shown_cap=$cap
            warn_armed=0   # skip a redundant warn on the way down
        fi
    elif (( cap <= WARN_PCT )); then
        if (( warn_armed )); then
            notify normal "Battery low" \
                "${cap}% remaining — consider plugging in." "$WARN_TIMEOUT_MS"
            warn_armed=0
        fi
        # Above the critical band again: re-arm it so a fresh descent re-alerts.
        crit_shown_cap=""
    else
        # Comfortably above both bands: resolved — clear any notification and
        # re-arm everything.
        dismiss
        warn_armed=1
        crit_shown_cap=""
    fi

    # Poll fast while discharging in a low band so a persistent popup's
    # percentage keeps pace with the draining battery; slow otherwise.
    if (( charging == 0 && cap <= WARN_PCT )); then
        wait_secs=$FAST_INTERVAL
    else
        wait_secs=$INTERVAL
    fi
}

# Singleton: bail if a monitor is already running (leftover from a previous
# Hyprland instance, or a manual re-run). The lock auto-releases on death, so
# a crashed monitor won't block the next login.
exec 9>"${XDG_RUNTIME_DIR:-/tmp}/hypr-battery-monitor.lock" || exit 0
flock -n 9 || exit 0

# Subscribe to power_supply udev events on a dedicated fd. `read -t` on this fd
# is our pacing primitive: it returns early (0) the instant an event arrives,
# or on timeout (>128) after $wait_secs for the periodic capacity check.
#
# We run udevadm via a FIFO (rather than `exec {UDEV}< <(...)`) so we hold its
# PID and can kill it — a process-substitution child would be orphaned when
# this script is terminated, leaking a udevadm per restart. A trap tears it
# down on any exit.
UDEV_PID=""
UDEV=""
start_udev() {
    [[ -n $UDEV_PID ]] && kill "$UDEV_PID" 2>/dev/null
    [[ -n $UDEV ]] && exec {UDEV}<&-
    local fifo
    fifo=$(mktemp -u) || return
    mkfifo "$fifo" || return
    stdbuf -oL udevadm monitor --udev --subsystem-match=power_supply >"$fifo" 2>/dev/null &
    UDEV_PID=$!
    exec {UDEV}< "$fifo"   # blocks until the writer above opens its end
    rm -f "$fifo"          # unlink the name; both open fds stay valid
}
cleanup() { [[ -n $UDEV_PID ]] && kill "$UDEV_PID" 2>/dev/null; }
# cleanup on EXIT covers every path; INT/TERM must *exit* (a trapped signal no
# longer terminates on its own) so the process actually stops on logout/pkill
# and the EXIT trap reaps the child.
trap cleanup EXIT
trap 'exit 143' TERM
trap 'exit 130' INT
start_udev

wait_secs=$INTERVAL   # evaluate() adapts this; default until the first read
while true; do
    evaluate
    if read -t "$wait_secs" -u "$UDEV" _; then
        # A power event (plug/unplug) arrived. udev emits several lines per
        # event — drain the burst so we re-evaluate once, not N times.
        while read -t 0.2 -u "$UDEV" _; do :; done
    elif (( $? <= 128 )); then
        # Not a timeout -> the monitor died (EOF). Restart it (start_udev
        # tears down the old fd/pid) without busy-spinning, then fall through.
        sleep 2
        start_udev
    fi
    # (timeout, $? > 128) falls straight through to the periodic re-evaluate.
done
